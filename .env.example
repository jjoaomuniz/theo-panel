# ── OpenRouter API ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── OpenClaw paths (inside container) ────────────────────────
OPENCLAW_DIR=/data/openclaw
MEMORY_FILE=/data/openclaw/MEMORY.md

# ── OpenClaw host path (for Docker volume mount) ─────────────
OPENCLAW_HOST_DIR=/root/.openclaw

# ── Cron jobs config ─────────────────────────────────────────
CRONJOBS_FILE=/data/cronjobs.json

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
